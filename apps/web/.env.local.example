# Copy to `apps/web/.env.local` (Next.js reads env from this app directory).

LIVE_MODE=fixture

# Voice escalation — Next does not load the repo-root `.env.local`; set these here for local full stack:
# VOICE_ESCALATE_URL=http://localhost:4000/calls/outbound
# DOORDASH_SUPPORT_NUMBER=+15551234567
# VOICE_SHARED_SECRET=   # same as apps/voice/.env.local if you use a secret

# Optional — real TinyFish on /live (tunnel to port 3000):
# LIVE_MODE=tinyfish
# LIVE_PORTAL_BASE_URL=https://YOUR_SUBDOMAIN.ngrok-free.app
