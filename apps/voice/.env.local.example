# apps/voice — copy to .env.local; never commit .env.local.

# === Server ===
PORT=4000

# === ElevenLabs ===
ELEVENLABS_API_KEY=elv_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_PHONE_NUMBER_ID=pn_...
ELEVENLABS_WEBHOOK_SECRET=whsec_...

# === Twilio (imported into ElevenLabs dashboard; not called directly) ===
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567

# === Ngrok (filled after `ngrok http 4000`) ===
NGROK_AUTHTOKEN=...
NGROK_PUBLIC_URL=https://counter-voice.ngrok-free.app

# === Anthropic (for Task 5 post-call transcript parsing) ===
ANTHROPIC_API_KEY=sk-ant-...

# === Demo ===
DEMO_SUPPORT_REP_PHONE=+15551234567
DEMO_MERCHANT_NAME="House of Curry"
DEMO_MERCHANT_ID=merchant_hoc

# === Hardening (security-review H1/H2/M4) ===
# Shared secret for /calls/outbound and /calls/history. MUST match the value in
# apps/web/.env.local. Leave unset in dev to disable auth (a boot warning will
# remind you); REQUIRED before exposing this service via ngrok.
VOICE_SHARED_SECRET=change-me-to-a-32-byte-random-string

# Comma-separated CORS origins for the dashboard. Default localhost:3000 if unset.
WEB_ORIGIN=http://localhost:3000

# Comma-separated E.164 phone numbers /calls/outbound may dial. If unset,
# falls back to DOORDASH_SUPPORT_NUMBER as the single allowed number.
ALLOWED_CALL_NUMBERS=+15551234567
