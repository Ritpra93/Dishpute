{
  "name": "counter",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:all": "pnpm -r test",
    "test:demo": "pnpm -F @counter/web test:demo",
    "dev:web": "pnpm -F @counter/web dev",
    "dev:voice": "pnpm -F @counter/voice dev",
    "seed": "pnpm -F @counter/web seed",
    "migrate": "pnpm -F @counter/voice exec tsx scripts/migrate-audio-columns.ts",
    "clean": "pnpm -r exec rm -rf dist .next node_modules/.cache",
    "ngrok:both": "ngrok start --all --config ngrok.yml"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
