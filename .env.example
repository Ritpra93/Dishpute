# Counter — Environment Variables
#
# Copy this file to `.env.local` at the repo root and at each app's directory.
# Never commit `.env.local`. Ritesh distributes real values via the shared vault.

# === Anthropic (Worker 2, Worker 3 for classifier proxy, Worker 4 for transcript parsing) ===
ANTHROPIC_API_KEY=sk-ant-...

# === TinyFish (Worker 1) ===
TINYFISH_API_KEY=tf_...

# Set to "cache" to short-circuit to fixture data — DEMO KILL SWITCH
# Leave unset or "live" for real TinyFish calls
SCRAPER_MODE=live

# === ElevenLabs (Worker 4) ===
ELEVENLABS_API_KEY=elv_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_PHONE_NUMBER_ID=pn_...
ELEVENLABS_WEBHOOK_SECRET=whsec_...

# === Twilio (Worker 4) ===
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567

# === Ngrok (Worker 4) ===
NGROK_AUTHTOKEN=...
# Updated at runtime once tunnel is live:
NGROK_PUBLIC_URL=https://counter-voice.ngrok-free.app

# === Stripe (Worker 3) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# === Demo configuration ===
# Number the voice agent calls (teammate's verified number acting as "support rep")
DEMO_SUPPORT_REP_PHONE=+15551234567
DEMO_MERCHANT_NAME="House of Curry"
DEMO_MERCHANT_ID=merchant_hoc

# === Internal service URLs (defaults work locally) ===
VOICE_SERVICE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000

# === Voice service hardening (security-review H1/H2/M4) ===
# Shared secret for apps/web → apps/voice server-to-server calls. Set the SAME
# value in apps/voice/.env.local AND apps/web/.env.local. If unset on the voice
# side, /calls/outbound is unauthenticated (dev-mode fallback) and a warning is
# logged at boot. MUST be set before exposing apps/voice via ngrok in prod.
VOICE_SHARED_SECRET=change-me-to-a-32-byte-random-string

# CORS allowlist for apps/voice. Comma-separated origins. Default is
# http://localhost:3000 — override in prod with your dashboard's real origin.
WEB_ORIGIN=http://localhost:3000

# Allowlist of phone numbers /calls/outbound is permitted to dial. Comma-
# separated E.164. If unset, falls back to DOORDASH_SUPPORT_NUMBER as a
# single-number allowlist. If both unset, only the E.164 format check applies.
ALLOWED_CALL_NUMBERS=+15551234567
