# Counter — Environment Variables
#
# Copy this file to `.env.local` at the repo root and at each app's directory.
# Never commit `.env.local`. Ritesh distributes real values via the shared vault.
#
# ─── SECRET ROTATION CHECKLIST (run before every public deploy) ─────────────
# Any value in this file that has ever been committed, emailed, pasted into a
# shared doc, or checked into a local `.env.local` on a developer laptop is
# considered leaked and MUST be rotated before going to production:
#   1. ANTHROPIC_API_KEY     — regenerate at console.anthropic.com → API Keys
#   2. TINYFISH_API_KEY      — regenerate in TinyFish dashboard
#   3. ELEVENLABS_API_KEY    — regenerate at elevenlabs.io → API Keys
#   4. ELEVENLABS_WEBHOOK_SECRET — regenerate in the ElevenLabs agent settings
#                             (also update apps/voice .env.local)
#   5. TWILIO_AUTH_TOKEN     — rotate in Twilio console → Account → API keys
#   6. STRIPE_SECRET_KEY     — roll key in Stripe Dashboard → Developers
#                             (expires the old key after a grace window)
#   7. NGROK_AUTHTOKEN       — regenerate in ngrok dashboard if shared
#   8. VOICE_SHARED_SECRET   — generate a fresh 32-byte hex value and set it
#                             identically in apps/web AND apps/voice
#   9. COUNTER_WEB_API_KEY   — required in production for privileged web API
#                             routes (/api/scan, /api/disputes/*/escalate,
#                             /api/disputes/*/submit, /api/disputes/submit-all,
#                             /api/stripe/onboarding, /api/transfers/demo-arm).
#                             Send as `x-counter-token: <key>`.
# After rotating, redeploy both apps with the new values and confirm
# apps/voice /webhooks/elevenlabs/post-call still returns 200 (signature
# verification uses the ElevenLabs webhook secret).

# === Anthropic (Worker 2, Worker 3 for classifier proxy, Worker 4 for transcript parsing) ===
ANTHROPIC_API_KEY=sk-ant-...

# === TinyFish (Worker 1) ===
TINYFISH_API_KEY=tf_...

# Set to "cache" to short-circuit to fixture data — DEMO KILL SWITCH
# Leave unset or "live" for real TinyFish calls
SCRAPER_MODE=live

# === ElevenLabs (Worker 4) ===
ELEVENLABS_API_KEY=elv_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_PHONE_NUMBER_ID=pn_...
ELEVENLABS_WEBHOOK_SECRET=whsec_...

# === Twilio (Worker 4) ===
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567

# === Ngrok (Worker 4) ===
NGROK_AUTHTOKEN=...
# Updated at runtime once tunnel is live:
NGROK_PUBLIC_URL=https://counter-voice.ngrok-free.app

# === Stripe (Worker 3) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# === Live demo mode (apps/web /live page) ===
# "fixture" (default): scripted replay — works offline, no TinyFish or tunnel.
# "tinyfish": real TinyFish SSE; needs TINYFISH_API_KEY + https LIVE_PORTAL_BASE_URL (ngrok → :3000).
LIVE_MODE=fixture
LIVE_PORTAL_BASE_URL=

# === Demo configuration ===
# Number the voice agent calls (teammate's verified number acting as "support rep")
DEMO_SUPPORT_REP_PHONE=+15551234567
DEMO_MERCHANT_NAME="House of Curry"
DEMO_MERCHANT_ID=merchant_hoc

# === Internal service URLs (defaults work locally) ===
VOICE_SERVICE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000

# === Voice ↔ dashboard (same value in apps/voice and apps/web .env.local) ===
# Required when NODE_ENV=production on apps/voice; sent as x-counter-token from web.
VOICE_SHARED_SECRET=
# Web POSTs here for real escalations (e.g. ngrok URL + /calls/outbound).
# In `pnpm dev` (NODE_ENV=development), apps/web defaults to VOICE_SERVICE_URL + /calls/outbound if unset.
VOICE_ESCALATE_URL=

# === Web API key (guards privileged Next.js API routes) ===
# REQUIRED in production. When unset in development, privileged routes run
# unauthenticated with a startup warning. Clients must send the value as
# the `x-counter-token` request header. See apps/web/lib/api-guard.ts.
COUNTER_WEB_API_KEY=
