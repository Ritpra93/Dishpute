# Counter — Environment Variables
#
# Copy this file to `.env.local` at the repo root and at each app's directory.
# Never commit `.env.local`. Ritesh distributes real values via the shared vault.

# === Anthropic (Worker 2, Worker 3 for classifier proxy, Worker 4 for transcript parsing) ===
ANTHROPIC_API_KEY=sk-ant-...

# === TinyFish (Worker 1) ===
TINYFISH_API_KEY=tf_...

# Set to "cache" to short-circuit to fixture data — DEMO KILL SWITCH
# Leave unset or "live" for real TinyFish calls
SCRAPER_MODE=live

# === ElevenLabs (Worker 4) ===
ELEVENLABS_API_KEY=elv_...
ELEVENLABS_AGENT_ID=agent_...
ELEVENLABS_PHONE_NUMBER_ID=pn_...
ELEVENLABS_WEBHOOK_SECRET=whsec_...

# === Twilio (Worker 4) ===
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+15551234567

# === Ngrok (Worker 4) ===
NGROK_AUTHTOKEN=...
# Updated at runtime once tunnel is live:
NGROK_PUBLIC_URL=https://counter-voice.ngrok-free.app

# === Stripe (Worker 3) ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# === Demo configuration ===
# Number the voice agent calls (teammate's verified number acting as "support rep")
DEMO_SUPPORT_REP_PHONE=+15551234567
DEMO_MERCHANT_NAME="House of Curry"
DEMO_MERCHANT_ID=merchant_hoc

# === Internal service URLs (defaults work locally) ===
VOICE_SERVICE_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000

# === Voice escalation wiring (apps/web reads these) ===
# When set, /api/disputes/[id]/escalate forwards to apps/voice's /calls/outbound.
# Leave UNSET to keep the dashboard in safe "stubbed" mode (no real phone call).
# Local default once apps/voice is running:
VOICE_ESCALATE_URL=http://localhost:4000/calls/outbound
# E.164 number the agent will dial. Use your own verified Twilio number for testing.
DOORDASH_SUPPORT_NUMBER=+15551234567

# Demo runbook (3 shells):
#   1. ngrok http 4000           # copy https URL into NGROK_PUBLIC_URL above
#   2. pnpm -F @counter/voice dev
#   3. pnpm dev:web              # then click "Call platform" on a denied dispute

# === GitHub MCP (optional, only for Cursor/Claude Code dev loop) ===
# Personal access token used by .mcp.json's `github` server.
# Generate at https://github.com/settings/tokens with the minimal scopes you need (usually `repo`).
# Never commit .mcp.json with a literal token — it is gitignored for that reason.
GITHUB_PAT=ghp_...

# === Vanta MCP (apps/voice) ===
# Absolute path to a JSON file containing { "client_id": "...", "client_secret": "..." }
# from https://developer.vanta.com/docs/api-access-setup. Required ONLY to talk to a
# real Vanta tenant via @vantasdk/vanta-mcp-server. Leave UNSET to use the bundled
# fixtures in apps/voice/__fixtures__/vanta/* — the same code path runs either way.
# VANTA_ENV_FILE=/absolute/path/to/vanta-credentials.env

# === Trust-center proxy (apps/web) ===
# When set, apps/web /api/trust forwards to apps/voice's composite trust-center endpoint
# instead of returning the local fixture. Defaults to the local voice service URL.
# TRUST_PROXY_URL=http://localhost:4000/api/vanta/trust-center
